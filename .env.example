APP_NAME=Doc Quality Compliance Check
ENVIRONMENT=development
DEBUG=false

# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_USE

# ── MVP Demo User (single-user / smoke-test mode) ─────────────────────────────
# Use a real mailbox you control and a strong password (≥12 chars).
AUTH_MVP_EMAIL=you@your-domain.example
AUTH_MVP_PASSWORD=CHANGE_ME_BEFORE_USE
AUTH_MVP_ROLES=qm_lead
AUTH_MVP_ORG=YOUR-ORG

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (integration / staging / production):
DATABASE_URL=postgresql+psycopg2://dbuser:CHANGE_ME@localhost:5432/doc_quality
# SQLite (local smoke tests only — do NOT use in production):
# DATABASE_URL=sqlite:///./doc_quality.db

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
LOG_LEVEL=INFO
LOG_FORMAT=console
MAX_FILE_SIZE_MB=50
