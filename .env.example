APP_NAME=Doc Quality Compliance Check
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_USE

SESSION_COOKIE_NAME=dq_session
SESSION_COOKIE_SECURE=false

# Global request rate limiting
GLOBAL_RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_REQUESTS=240
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60

# Session TTL policy (minutes)
# remember_me=false => short session (2 hours)
SESSION_TTL_SHORT_MINUTES=120
# remember_me=true => persistent session (5 days)
SESSION_TTL_REMEMBER_ME_MINUTES=7200
AUTH_AUTO_PROVISION_MVP_USER=true
AUTH_RECOVERY_TTL_MINUTES=15
AUTH_RECOVERY_RATE_LIMIT_COUNT=5
AUTH_RECOVERY_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RECOVERY_DEBUG_EXPOSE_TOKEN=false
AUTH_LOGIN_RATE_LIMIT_COUNT=8
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=600

# ── MVP Demo User (single-user / smoke-test mode) ─────────────────────────────
# Defaults from application config; replace only if you need a different test account.
AUTH_MVP_EMAIL=demo@quality-station.ai
AUTH_MVP_PASSWORD=change-me
AUTH_MVP_ROLES=qm_lead
AUTH_MVP_ORG=QM-CORE-STATION
AUTH_ADMIN_EMAIL=admin@example.invalid
AUTH_ADMIN_PASSWORD=CHANGE_ME_ADMIN_BEFORE_USE
AUTH_ADMIN_ROLES=app_admin,qm_lead
AUTH_ADMIN_ORG=QM-ADMIN-STATION

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (integration / staging / production):
DATABASE_URL=postgresql+psycopg2://dbuser:CHANGE_ME@localhost:5432/doc_quality
# SQLite (local smoke tests only — do NOT use in production):
# DATABASE_URL=sqlite:///./doc_quality.db
DATABASE_ECHO=false

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_API_BASE_URL=https://api.perplexity.ai
LOG_LEVEL=INFO
LOG_FORMAT=console
METRICS_ENABLED=true
TRACING_ENABLED=true
TRACING_EXPORTER=none
TRACING_OTLP_ENDPOINT=
TRACING_SAMPLING_RATIO=1.0
TELEMETRY_SERVICE_NAME=doc-quality-api
BRIDGE_LOCAL_ONLY_ENFORCED=true
BRIDGE_EGRESS_POLICY=deny_external
BRIDGE_TOPOLOGY_PROOF_REQUIRED=true
BRIDGE_RUNTIME_TOPOLOGY_SOURCE=docker_inspect
BRIDGE_RUNTIME_TOPOLOGY_ALLOW_METADATA_FALLBACK=false
BRIDGE_CONTAINER_RUNTIME_BIN=docker
BRIDGE_ORCHESTRATOR_NAME=bridge-workflow-orchestrator
BRIDGE_ORCHESTRATOR_MODE=containerized-sandbox
BRIDGE_AGENT_NETWORK_ID=bridge-sandbox-network
BRIDGE_AGENT_CONTAINER_INSPECTION=bridge-agent-inspection
BRIDGE_AGENT_CONTAINER_COMPLIANCE=bridge-agent-compliance
BRIDGE_AGENT_CONTAINER_RESEARCH=bridge-agent-research
BRIDGE_AGENT_CONTAINER_QUALITY_GATE=bridge-agent-quality-gate
TEMPLATES_DIR=templates
REPORTS_OUTPUT_DIR=reports
MAX_FILE_SIZE_MB=50
