# Orchestrator environment example
# Copy this file to .env and fill in deployment-specific values.

# Backend Skills API used by CrewAI tools
BACKEND_BASE_URL=http://localhost:8000/api/v1

# Privacy routing: on-prem first for personal-data-bearing payloads
CREWAI_WORKFLOW_ENABLED=true
MODEL_VALIDATOR_ENABLED=true
MODEL_VALIDATOR_MAX_TOKENS=600

# On-prem Nemotron gateway (OpenAI-compatible endpoint)
# Use the real gateway URL from your deployment, for example:
# NEMOTRON_BASE_URL=https://nemotron-gateway.internal.example/v1
NEMOTRON_BASE_URL=
NEMOTRON_API_KEY=
NEMOTRON_MODEL=nemotron-parse

# Optional external fallback providers (kept as controlled fallback paths)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Runtime safety limits
MAX_STEPS=20
MAX_RETRIES_PER_STEP=3
MAX_TOKEN_BUDGET_PER_RUN=100000
STEP_TIMEOUT_SECONDS=60
GLOBAL_RUN_TIMEOUT_SECONDS=300

# API auth for the orchestrator service
API_SECRET_KEY=change-me-in-production
