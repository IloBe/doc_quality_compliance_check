# PostgreSQL Configuration for Doc Quality Compliance Check
# Copy to .env and adjust connection string if using non-default credentials

# ============================================================================
# DATABASE CONFIGURATION (Phase 0 - MVP)
# ============================================================================
# Required for: User sessions, HITL reviews, audit events, compliance data

# Local PostgreSQL (recommended for development)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/doc_quality

# Alternative: Docker Compose (see docker-compose.yml)
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/doc_quality

# Alternative: Remote PostgreSQL (production-like)
# DATABASE_URL=postgresql+psycopg2://postgres:your_secure_password@your-host.com:5432/doc_quality

# SQL query logging (development only - set to false in production)
DATABASE_ECHO=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=console
METRICS_ENABLED=true
TRACING_ENABLED=true
TRACING_EXPORTER=none
TRACING_OTLP_ENDPOINT=
TRACING_SAMPLING_RATIO=1.0
TELEMETRY_SERVICE_NAME=doc-quality-api

# ============================================================================
# AUTHENTICATION (Phase 0 - Email/Password MVP)
# ============================================================================
AUTH_MVP_EMAIL=demo@quality-station.ai
AUTH_MVP_PASSWORD=change-me
AUTH_MVP_ROLES=qm_lead
AUTH_MVP_ORG=QM-CORE-STATION

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Set in frontend/.env.local instead:
# NEXT_PUBLIC_API_ORIGIN=http://localhost:8000
