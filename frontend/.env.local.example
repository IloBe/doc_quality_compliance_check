# Frontend -> Backend API origin for auth/session calls
# Copy to .env.local and adjust as needed.
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8000

# Optional: login-page auth health polling badge (default: enabled).
# Set to false to hide it.
NEXT_PUBLIC_ENABLE_AUTH_HEALTH_CHECK=true

# Optional: direct health endpoint origin for the badge.
# Uses direct backend call (not Next.js proxy) to avoid proxy ECONNREFUSED noise.
NEXT_PUBLIC_HEALTH_ORIGIN=http://127.0.0.1:8000
